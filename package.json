{
  "name": "kiona-ai",
  "version": "0.1.0",
  "description": "AI Virtual Assistant dengan dual mode local & cloud, Live2D avatar, voice, dan tools integration",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:api": "workspace api dev",
    "dev:web": "workspace web dev",
    "dev:desktop": "workspace desktop dev",
    "build": "npm run build --workspaces",
    "start": "workspace api start",
    "start:prod": "NODE_ENV=production npm start",
    "test": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "db:setup": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "setup:models": "node scripts/setup-models.js",
    "setup:minecraft": "node scripts/setup-minecraft.js",
    "add-tool": "node scripts/add-tool.js",
    "docker:build": "docker build -t kiona-ai:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "clean": "rm -rf node_modules dist .next .turbo"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.0.0",
    "typescript": "^5.3.0",
    "tailwindcss": "^3.3.0",
    "electron": "^27.0.0",
    "express": "^4.18.0",
    "prisma": "^5.7.0",
    "@prisma/client": "^5.7.0",
    "langchain": "^0.1.0",
    "openai": "^4.28.0",
    "@anthropic-ai/sdk": "^0.11.0",
    "google-generative-ai": "^0.1.0",
    "@openrouter/ai-sdk": "^1.0.0",
    "ollama": "^0.1.0",
    "whisper-web": "^1.0.0",
    "elevenlabs-js": "^0.1.0",
    "pixi.js": "^8.0.0",
    "live2d-js": "^1.0.0",
    "mineflayer": "^4.16.0",
    "redis": "^4.6.0",
    "bullmq": "^5.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/express": "^4.17.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "concurrently": "^8.2.0",
    "turbo": "^1.10.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}