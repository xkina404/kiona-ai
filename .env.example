# Application
NODE_ENV=development
APP_MODE=hybrid
APP_NAME=Kiona AI
APP_VERSION=0.1.0
APP_PORT=3000

# Cloud Models - OpenRouter
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Cloud Models - Anthropic
ANTHROPIC_API_KEY=your_anthropic_key

# Cloud Models - Google
GEMINI_API_KEY=your_gemini_key

# Cloud Models - OpenAI
OPENAI_API_KEY=your_openai_key

# Local Models - Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama2

# Web Search
SEARCH_API_KEY=your_search_api_key
SEARCH_ENGINE_ID=your_google_cse_id
SEARCH_ENGINE_TYPE=google

# Voice - Text to Speech
ELEVENLABS_API_KEY=your_elevenlabs_key
GOOGLE_CLOUD_TTS_KEY=your_google_tts_key
TTS_PROVIDER=elevenlabs
TTS_VOICE=21m00Tcm4TlvDq8ikWAM
TTS_LANGUAGE=en-US
TTS_SPEED=1.0

# Voice - Speech to Text
WHISPER_API_KEY=your_whisper_key
WHISPER_MODEL=base
STT_LANGUAGE=auto

# Avatar
AVATAR_DEFAULT=default_v1
AVATAR_MODE=live2d
AVATAR_ANIMATION_ENABLED=true
AVATAR_AUDIO_SYNC=true

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kiona_ai
DATABASE_SHADOW_URL=postgresql://user:password@localhost:5432/kiona_ai_shadow
REDIS_URL=redis://localhost:6379

# Minecraft Integration
MINECRAFT_ENABLED=true
MINECRAFT_HOST=localhost
MINECRAFT_PORT=25565
MINECRAFT_USERNAME=KionaBot
MINECRAFT_PASSWORD=optional

# RAG Configuration
RAG_ENABLED=true
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=100
RAG_SIMILARITY_THRESHOLD=0.7

# Tools & Plugins
TOOLS_ENABLED=true
TOOLS_GITHUB_TOKEN=your_github_token
TOOLS_AUTO_LOAD=true

# Security
JWT_SECRET=your_jwt_secret_key_min_32_chars
ENCRYPTION_KEY=your_encryption_key_min_32_chars

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=logs/app.log

# Feature Flags
FEATURE_WEB_SEARCH=true
FEATURE_RAG=true
FEATURE_VOICE=true
FEATURE_MINECRAFT=true
FEATURE_TOOLS=true
FEATURE_STREAMING=true
FEATURE_FUNCTION_CALLING=true

# Development
DEBUG=false
DEBUG_AI=false
DEBUG_VOICE=false
DEBUG_AVATAR=false

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn

# Telemetry
TELEMETRY_ENABLED=false